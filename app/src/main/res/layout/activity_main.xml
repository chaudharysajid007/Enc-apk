<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒 File Protector"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Test Mode - Educational Purpose"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginTop="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ Only works in: /storage/emulated/0/Test/all files"
            android:textSize="12sp"
            android:textColor="#FF5722"
            android:layout_marginTop="8dp"
            android:background="#FFF3E0"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- Button -->
    <Button
        android:id="@+id/protectButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔒 PROTECT FILES"
        android:textSize="18sp"
        android:textAllCaps="false"
        android:padding="16dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:elevation="2dp"/>

    <!-- Status Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status Log"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"/>

    <!-- Scroll Area -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:padding="8dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📂 Ready to protect files...\n\nPlease create this folder:\n/storage/emulated/0/Test/all files\n\nThen add some files and press the button."
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:padding="12dp"
            android:textColor="#333333"
            android:fontFamily="monospace"/>
    </ScrollView>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📌 Test files only | No system files affected"
        android:textSize="12sp"
        android:textColor="#999999"
        android:gravity="center"
        android:padding="12dp"/>

</LinearLayout>